FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    ca-certificates \
    curl \
    make \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Rust 1.85.0 via rustup
ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH=/usr/local/cargo/bin:$PATH \
    RUST_VERSION=1.94.0

RUN curl -fsSL https://sh.rustup.rs | \
    sh -s -- -y --no-modify-path --default-toolchain ${RUST_VERSION} --profile minimal \
    && rustup --version \
    && rustc --version \
    && cargo --version

# Install Claude Code via official standalone installer
RUN curl -fsSL https://claude.ai/install.sh | bash \
    && cp /root/.local/bin/claude /usr/local/bin/claude

WORKDIR /workspace

# Install alog from latest GitHub release
RUN ALOG_VERSION=$(curl -fsSL https://api.github.com/repos/prettysmartdev/alog/releases/latest \
		| grep '"tag_name"' \
		| sed 's/.*"tag_name": *"\([^"]*\)".*/\1/') \
	&& curl -fsSL "https://github.com/prettysmartdev/alog/releases/download/${ALOG_VERSION}/alog-linux-amd64.tar.gz" \
		-o /tmp/alog.tar.gz \
	&& tar -xzf /tmp/alog.tar.gz -C /usr/local/bin/ \
	&& rm /tmp/alog.tar.gz
